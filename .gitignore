# ============================================================
# VibeStudio — .gitignore
# ============================================================

# --- Xcode / Build ---
build/
DerivedData/
*.xcarchive
*.xcresult
*.ipa
*.dmg
*.dSYM.zip
*.dSYM

# Xcode user-specific data
*.xcuserdata/
xcuserdata/
*.xcscmblueprint
*.xccheckout

# Xcode workspace settings (user-specific)
*.xcworkspace/xcuserdata/
*.xcworkspace/xcshareddata/IDEWorkspaceChecks.plist

# --- Swift Package Manager ---
.build/
.swiftpm/
Packages/

# --- macOS ---
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo
*~

# --- Secrets (never commit) ---
*.p12
*.mobileprovision
*.provisionprofile
AuthKey_*.p8
.env
.env.*
.env.local
*.env

# --- Misc ---
*.log
*.tmp
swarm-report/
cat
